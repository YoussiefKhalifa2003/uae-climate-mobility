# Copy to .env and edit as needed. Everything works without changes (simulation mode).

# --- Geography ---
PLACE="Downtown Dubai, Dubai, United Arab Emirates"
CENTER_LAT=25.1972
CENTER_LON=55.2744
UTM_EPSG=32640
TIMEZONE=Asia/Dubai

# --- Simulation ---
AGENT_COUNT=20000
SIM_FPS=20
RASTER_RESOLUTION_M=5.0

# --- Ambient fallback (used when live data is off/unavailable) ---
AIR_TEMP_C=41.0
RELATIVE_HUMIDITY=55.0
WIND_SPEED_MS=3.0
WIND_DIR_DEG=315.0

# --- Hybrid data ---
# Open-Meteo needs no key. For real air quality, add an OpenWeather key:
OPENWEATHER_API_KEY=
# Optional TomTom Traffic Flow API for live drive speeds (otherwise agent simulation):
TOMTOM_API_KEY=
USE_LIVE_DATA=true
LIVE_DATA_TIMEOUT_S=4.0

# --- Compute ---
# Set to true to force the NumPy CPU backend even if CuPy is installed.
FORCE_CPU=false

# Set to true to skip OSM and use the offline synthetic city sector.
# Default is false (loads real Downtown Dubai from OpenStreetMap).
FORCE_SYNTHETIC=false

# --- Server ---
HOST=0.0.0.0
PORT=8000
